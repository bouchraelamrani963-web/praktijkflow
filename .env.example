# Local app URL used for generated claim links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/praktijkflow"

# Firebase client config
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase Admin SDK
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=""
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=""

# E-mail offer delivery
# Fail-safe: only exact EMAIL_TEST_MODE=false sends real e-mail.
EMAIL_TEST_MODE="true"
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""
EMAIL_FROM=""
EMAIL_REPLY_TO=""
# Automatic offers stay test-only unless this is exact true and EMAIL_TEST_MODE=false.
AUTO_OFFER_ENABLED="false"

# SMS delivery, optional and reserved for later.
# Fail-safe: only exact SMS_TEST_MODE=false sends real SMS.
SMS_TEST_MODE="true"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Optional operational settings
CRON_SECRET=""
NEXT_PUBLIC_DEMO_MODE="false"
NEXT_PUBLIC_DEV_AUTH_BYPASS="false"
